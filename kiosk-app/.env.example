# Kiosk build-time configuration. Copy to `.env` and fill in as needed.
# Vite inlines these at build time, so rebuild (npm run build) after changing them.

# Admin PIN for the hidden stats panel's reset action (defaults to 2580 if unset).
VITE_ADMIN_PIN=2580

# ── Shared stats backend (optional) ──────────────────────────────────────────
# Leave VITE_STATS_ENDPOINT blank to keep this build local-only (no sync).
# See backend/apps-script/README.md for how to create the endpoint + key.

# Apps Script web-app URL (ends in /exec):
VITE_STATS_ENDPOINT=

# Same value as the WRITE_KEY script property on the Apps Script project:
VITE_STATS_KEY=

# A label to tell devices apart in the shared sheet (e.g. conference-stand-1):
VITE_KIOSK_ID=kiosk
