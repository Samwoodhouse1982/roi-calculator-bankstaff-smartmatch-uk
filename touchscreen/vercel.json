{
  "framework": null,
  "installCommand": "cd kiosk-app && npm install",
  "buildCommand": "cd kiosk-app && npm run build",
  "outputDirectory": "kiosk-app/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
